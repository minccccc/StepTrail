@page "/login"
@model StepTrail.Api.Pages.LoginModel
@{
    Layout = null;  // standalone page — no navbar needed before auth
    ViewData["Title"] = "Sign In";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In — StepTrail Ops</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />
    <style>
        body { background-color: #f8f9fa; }
        .login-card { max-width: 380px; }
    </style>
</head>
<body>
    <div class="d-flex justify-content-center align-items-center min-vh-100">
        <div class="login-card w-100 mx-3">
            <div class="text-center mb-4">
                <h4 class="fw-semibold mb-0">StepTrail Ops</h4>
                <p class="text-muted small">Operations Console</p>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h5 class="card-title mb-3">Sign in</h5>

                    @if (Model.ErrorMessage is not null)
                    {
                        <div class="alert alert-danger py-2 small">@Model.ErrorMessage</div>
                    }

                    <form method="post">
                        <input type="hidden" name="returnUrl" value="@Request.Query["returnUrl"]" />

                        <div class="mb-3">
                            <label for="Username" class="form-label">Username</label>
                            <input id="Username" name="Username" type="text"
                                   class="form-control" autocomplete="username"
                                   value="@Model.Username" autofocus required />
                        </div>

                        <div class="mb-4">
                            <label for="Password" class="form-label">Password</label>
                            <input id="Password" name="Password" type="password"
                                   class="form-control" autocomplete="current-password" required />
                        </div>

                        <button type="submit" class="btn btn-dark w-100">Sign in</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
