@page "/ops/workflows/details"
@using System.Linq
@model StepTrail.Api.Pages.Workflows.DetailsModel
@{
    ViewData["Title"] = Model.Instance is null ? "Instance Not Found" : $"Instance {Model.Id.ToString()[..8]}...";
    var inst = Model.Instance;
    var trail = Model.Trail;
    bool canRetry = inst?.CanRetry ?? false;
    bool canReplay = inst?.CanReplay ?? false;
    bool canCancel = inst?.CanCancel ?? false;
    bool canArchive = inst?.CanArchive ?? false;
    bool isArchived = inst?.Status == "Archived";

    var totalSteps = trail?.Steps.Count ?? 0;
    var completedSteps = trail?.Steps.Count(step => step.LatestStatus == "Completed") ?? 0;
    var activeSteps = trail?.Steps.Count(step => step.LatestStatus is "Running" or "Waiting" or "Pending") ?? 0;
    var failedSteps = trail?.Steps.Count(step => step.LatestStatus == "Failed") ?? 0;
    var retriedSteps = trail?.Steps.Count(step => step.Attempts.Count > 1) ?? 0;
    var hasTrailData = trail is not null && trail.Steps.Count > 0;
    var focusStep = ResolveFocusStep(trail, inst?.Status);
    var focusAttempt = focusStep is null || focusStep.Attempts.Count == 0 ? null : focusStep.Attempts[^1];
    var workflowRuns = BuildWorkflowRuns(trail);
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
        crossorigin="anonymous"></script>

@functions {
    static string StatusBadge(string status) => status switch
    {
        "Pending" => "<span class=\"badge bg-secondary\">Pending</span>",
        "Running" => "<span class=\"badge bg-primary\">Running</span>",
        "AwaitingRetry" => "<span class=\"badge bg-warning text-dark\">Awaiting Retry</span>",
        "Completed" => "<span class=\"badge bg-success\">Completed</span>",
        "Failed" => "<span class=\"badge bg-danger\">Failed</span>",
        "Cancelled" => "<span class=\"badge bg-warning text-dark\">Cancelled</span>",
        "Archived" => "<span class=\"badge bg-light text-secondary border\">Archived</span>",
        _ => $"<span class=\"badge bg-light text-dark\">{status}</span>"
    };

    static string StepStatusBadge(string status) => status switch
    {
        "NotStarted" => "<span class=\"badge bg-light text-dark border\">Not Started</span>",
        "Pending" => "<span class=\"badge bg-secondary\">Pending</span>",
        "Waiting" => "<span class=\"badge bg-info text-dark\">Waiting</span>",
        "Running" => "<span class=\"badge bg-primary\">Running</span>",
        "Completed" => "<span class=\"badge bg-success\">Completed</span>",
        "Failed" => "<span class=\"badge bg-danger\">Failed</span>",
        "Cancelled" => "<span class=\"badge bg-warning text-dark\">Cancelled</span>",
        _ => $"<span class=\"badge bg-light text-dark\">{status}</span>"
    };

    static string ClassificationBadge(string classification) => classification switch
    {
        "TransientFailure" => "<span class=\"badge bg-warning text-dark\">Transient</span>",
        "PermanentFailure" => "<span class=\"badge bg-danger\">Permanent</span>",
        "InvalidConfiguration" => "<span class=\"badge bg-dark\">Invalid Config</span>",
        "InputResolutionFailure" => "<span class=\"badge bg-dark\">Input Resolution</span>",
        _ => $"<span class=\"badge bg-light text-dark\">{classification}</span>"
    };

    static string TriggerBadge(string? triggerType) => triggerType switch
    {
        "Webhook" => "<span class=\"badge bg-info text-dark\">Webhook</span>",
        "Manual" => "<span class=\"badge bg-secondary\">Manual</span>",
        "Schedule" => "<span class=\"badge bg-warning text-dark\">Schedule</span>",
        _ => "<span class=\"text-muted\">-</span>"
    };

    static string Truncate(string text, int max) =>
        text.Length <= max ? text : text[..max] + "...";

    static string FormatDuration(TimeSpan d)
    {
        if (d.TotalSeconds < 1) return $"{d.TotalMilliseconds:F0}ms";
        if (d.TotalMinutes < 1) return $"{d.TotalSeconds:F1}s";
        if (d.TotalHours < 1)
        {
            var sec = d.Seconds;
            return sec > 0 ? $"{(int)d.TotalMinutes}m {sec}s" : $"{(int)d.TotalMinutes}m";
        }
        var min = d.Minutes;
        return min > 0 ? $"{(int)d.TotalHours}h {min}m" : $"{(int)d.TotalHours}h";
    }

    static string FormatUtc(DateTimeOffset value) =>
        value.UtcDateTime.ToString("yyyy-MM-dd HH:mm:ss 'UTC'");

    static string AttemptDuration(TrailStepAttempt attempt)
    {
        if (!attempt.StartedAt.HasValue) return "Not started";
        if (!attempt.CompletedAt.HasValue) return "Still running";
        return FormatDuration(attempt.CompletedAt.Value - attempt.StartedAt.Value);
    }

    static string AttemptDurationShort(TrailStepAttempt attempt)
    {
        if (!attempt.StartedAt.HasValue || !attempt.CompletedAt.HasValue) return "-";
        return FormatDuration(attempt.CompletedAt.Value - attempt.StartedAt.Value);
    }

    static TrailStep? ResolveFocusStep(WorkflowTrail? trail, string? workflowStatus)
    {
        if (trail is null || trail.Steps.Count == 0) return null;

        if (workflowStatus is "Failed" or "AwaitingRetry")
        {
            return trail.Steps.LastOrDefault(step => step.LatestStatus == "Failed")
                ?? trail.Steps.FirstOrDefault(step => step.LatestStatus is "Running" or "Waiting" or "Pending")
                ?? trail.Steps[^1];
        }

        if (workflowStatus is "Running" or "Pending")
        {
            return trail.Steps.FirstOrDefault(step => step.LatestStatus is "Running" or "Waiting" or "Pending")
                ?? trail.Steps.LastOrDefault(step => step.LatestStatus == "Failed")
                ?? trail.Steps[^1];
        }

        return trail.Steps.LastOrDefault(step => step.Attempts.Count > 1)
            ?? trail.Steps[^1];
    }

    static string FocusHeading(string workflowStatus, TrailStep step) => step.LatestStatus switch
    {
        "Failed" => "Needs attention",
        "Running" => "Current active step",
        "Waiting" => "Current waiting step",
        "Pending" => "Queued next",
        _ when workflowStatus == "Completed" => "Most recent completed step",
        _ => "Most relevant step"
    };

    static string FocusPanelClass(string status) => status switch
    {
        "Failed" => "is-failed",
        "Running" => "is-active",
        "Pending" => "is-active",
        "Waiting" => "is-waiting",
        _ => string.Empty
    };

    static string StepShellClass(bool isFailed, bool isActive, bool hasRetries)
    {
        var classes = new List<string>();
        if (isFailed) classes.Add("is-failed");
        if (isActive) classes.Add("is-active");
        if (hasRetries) classes.Add("is-retried");
        return string.Join(" ", classes);
    }

    static List<WorkflowRunView> BuildWorkflowRuns(WorkflowTrail? trail)
    {
        if (trail is null || trail.Steps.Count == 0)
        {
            return [];
        }

        var flattened = trail.Steps
            .SelectMany(step => step.Attempts.Select(attempt => new WorkflowRunStepView
            {
                StepKey = step.StepKey,
                StepType = step.StepType,
                StepOrder = step.StepOrder,
                Attempt = attempt.Attempt,
                Status = attempt.Status,
                FailureClassification = attempt.FailureClassification,
                ScheduledAt = attempt.ScheduledAt,
                StartedAt = attempt.StartedAt,
                CompletedAt = attempt.CompletedAt,
                Error = attempt.Error
            }))
            .OrderBy(step => step.ScheduledAt)
            .ThenBy(step => step.StepOrder)
            .ThenBy(step => step.StartedAt ?? step.ScheduledAt)
            .ToList();

        if (flattened.Count == 0)
        {
            return [];
        }

        var groups = new List<List<WorkflowRunStepView>>();
        List<WorkflowRunStepView>? currentGroup = null;
        int? lastStepOrder = null;

        foreach (var step in flattened)
        {
            if (currentGroup is null || (lastStepOrder.HasValue && step.StepOrder <= lastStepOrder.Value))
            {
                currentGroup = [];
                groups.Add(currentGroup);
            }

            currentGroup.Add(step);
            lastStepOrder = step.StepOrder;
        }

        var runs = new List<WorkflowRunView>(groups.Count);

        for (var i = 0; i < groups.Count; i++)
        {
            var group = groups[i];
            var first = group[0];
            var last = group[^1];

            var kindLabel = i == 0
                ? "Initial pass"
                : first.StepOrder <= 1
                    ? "Replay from the beginning"
                    : $"Resumed from {first.StepKey}";

            runs.Add(new WorkflowRunView
            {
                RunNumber = i + 1,
                KindLabel = kindLabel,
                StartedFromStep = first.StepKey,
                EndedAtStep = last.StepKey,
                FinalStatus = last.Status,
                FinalFailureClassification = last.FailureClassification,
                FinalError = last.Error,
                StartedAt = first.StartedAt ?? first.ScheduledAt,
                CompletedAt = last.CompletedAt,
                Steps = group
            });
        }

        return runs;
    }

    static string RunDuration(WorkflowRunView run)
    {
        if (!run.CompletedAt.HasValue)
        {
            return "Still running";
        }

        return FormatDuration(run.CompletedAt.Value - run.StartedAt);
    }

    static string RunCardClass(string status) => status switch
    {
        "Failed" => "is-failed",
        "Running" => "is-running",
        "Pending" => "is-running",
        "Waiting" => "is-waiting",
        "Completed" => "is-completed",
        _ => string.Empty
    };

    static string RunChipClass(string status) => status switch
    {
        "Failed" => "is-terminal-failed",
        "Running" => "is-terminal-running",
        "Pending" => "is-terminal-running",
        "Waiting" => "is-terminal-running",
        "Completed" => "is-terminal-completed",
        _ => string.Empty
    };

    static string PrettyJson(string json)
    {
        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(json);
            return System.Text.Json.JsonSerializer.Serialize(
                doc,
                new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return json;
        }
    }

    private sealed class WorkflowRunView
    {
        public required int RunNumber { get; init; }
        public required string KindLabel { get; init; }
        public required string StartedFromStep { get; init; }
        public required string EndedAtStep { get; init; }
        public required string FinalStatus { get; init; }
        public string? FinalFailureClassification { get; init; }
        public string? FinalError { get; init; }
        public required DateTimeOffset StartedAt { get; init; }
        public DateTimeOffset? CompletedAt { get; init; }
        public required IReadOnlyList<WorkflowRunStepView> Steps { get; init; }
    }

    private sealed class WorkflowRunStepView
    {
        public required string StepKey { get; init; }
        public string? StepType { get; init; }
        public required int StepOrder { get; init; }
        public required int Attempt { get; init; }
        public required string Status { get; init; }
        public string? FailureClassification { get; init; }
        public required DateTimeOffset ScheduledAt { get; init; }
        public DateTimeOffset? StartedAt { get; init; }
        public DateTimeOffset? CompletedAt { get; init; }
        public string? Error { get; init; }
    }
}

<style>
    .trail-overview {
        display: grid;
        gap: .75rem;
        grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    }

    .trail-stat {
        background: linear-gradient(180deg, #fff 0%, #f8fafc 100%);
        border: 1px solid #dfe5ec;
        border-radius: .9rem;
        box-shadow: 0 .35rem .9rem rgba(15, 23, 42, .04);
        padding: .85rem .95rem;
    }

    .trail-stat-label {
        color: #64748b;
        display: block;
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .08em;
        margin-bottom: .25rem;
        text-transform: uppercase;
    }

    .trail-stat-value {
        color: #0f172a;
        display: block;
        font-size: 1.45rem;
        font-weight: 700;
        line-height: 1.1;
    }

    .trail-focus {
        background: #fff;
        border: 1px solid #dfe5ec;
        border-radius: 1rem;
        box-shadow: 0 .45rem 1rem rgba(15, 23, 42, .05);
        padding: 1rem 1.1rem;
    }

    .trail-focus.is-failed {
        background: linear-gradient(180deg, #fff8f8 0%, #fff2f2 100%);
        border-color: #f1aeb5;
    }

    .trail-focus.is-active {
        background: linear-gradient(180deg, #f8fbff 0%, #f2f7ff 100%);
        border-color: #9ec5fe;
    }

    .trail-focus.is-waiting {
        background: linear-gradient(180deg, #f6fcff 0%, #eefbff 100%);
        border-color: #9eeaf9;
    }

    .trail-focus-kicker {
        color: #64748b;
        font-size: .74rem;
        font-weight: 700;
        letter-spacing: .08em;
        margin-bottom: .25rem;
        text-transform: uppercase;
    }

    .trail-subtitle {
        color: #6c757d;
        font-size: .92rem;
    }

    .step-row {
        position: relative;
        padding-left: 2.8rem;
        padding-bottom: .55rem;
    }

    .step-row::before {
        background: #d7dee7;
        bottom: -.1rem;
        content: "";
        left: .95rem;
        position: absolute;
        top: 2rem;
        width: 2px;
    }

    .step-row:last-child::before {
        display: none;
    }

    .step-icon {
        align-items: center;
        border-radius: 999px;
        color: #fff;
        display: flex;
        font-size: .78rem;
        font-weight: 700;
        height: 1.95rem;
        justify-content: center;
        left: 0;
        position: absolute;
        top: .45rem;
        width: 1.95rem;
        z-index: 1;
    }

    .step-icon.ok { background: #198754; }
    .step-icon.err { background: #dc3545; }
    .step-icon.run { background: #0d6efd; }
    .step-icon.wait { background: #6c757d; }

    .step-shell {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: .95rem;
        box-shadow: 0 .25rem .8rem rgba(15, 23, 42, .04);
        padding: .95rem 1rem;
    }

    .step-shell.is-failed {
        border-color: #f1aeb5;
        box-shadow: 0 .3rem .95rem rgba(220, 53, 69, .08);
    }

    .step-shell.is-active { border-color: #9ec5fe; }
    .step-shell.is-retried { border-color: #ffe69c; }

    .step-meta {
        color: #6c757d;
        display: flex;
        flex-wrap: wrap;
        gap: .35rem 1rem;
        margin-top: .45rem;
    }

    .step-meta span { white-space: nowrap; }

    .step-signals {
        display: flex;
        flex-wrap: wrap;
        gap: .4rem;
        margin-top: .55rem;
    }

    .signal-pill {
        border-radius: 999px;
        display: inline-flex;
        font-size: .76rem;
        font-weight: 600;
        padding: .2rem .6rem;
    }

    .signal-pill.retry { background: #fff3cd; color: #7a5a00; }
    .signal-pill.wait { background: #cff4fc; color: #055160; }

    .err-box {
        background: #fff5f5;
        border: 1px solid #f5c6cb;
        border-radius: .6rem;
        color: #842029;
        font-family: var(--bs-font-monospace);
        font-size: .82rem;
        margin-top: .7rem;
        padding: .7rem .8rem;
        white-space: pre-wrap;
        word-break: break-word;
    }

    .data-box {
        background: #1e1e1e;
        border-radius: .6rem;
        color: #d4d4d4;
        font-size: .79rem;
        max-height: 220px;
        overflow-y: auto;
        padding: .7rem .8rem;
        white-space: pre-wrap;
        word-break: break-word;
    }

    .attempt-note {
        background: #f8fafc;
        border: 1px dashed #cbd5e1;
        border-radius: .6rem;
        color: #64748b;
        padding: .55rem .7rem;
    }

    .run-perspective {
        display: grid;
        gap: .85rem;
    }

    .run-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 1rem;
        box-shadow: 0 .25rem .8rem rgba(15, 23, 42, .04);
        padding: 1rem 1.05rem;
    }

    .run-card.is-failed {
        border-color: #f1aeb5;
        box-shadow: 0 .3rem .95rem rgba(220, 53, 69, .08);
    }

    .run-card.is-running {
        border-color: #9ec5fe;
    }

    .run-card.is-waiting {
        border-color: #9eeaf9;
    }

    .run-card.is-completed {
        border-color: #badbcc;
    }

    .run-meta {
        color: #6c757d;
        display: flex;
        flex-wrap: wrap;
        gap: .35rem 1rem;
    }

    .run-meta span {
        white-space: nowrap;
    }

    .run-sequence {
        display: flex;
        flex-wrap: wrap;
        gap: .4rem;
        margin-top: .75rem;
    }

    .run-chip {
        align-items: center;
        background: #f8fafc;
        border: 1px solid #dbe4ee;
        border-radius: 999px;
        color: #334155;
        display: inline-flex;
        font-size: .76rem;
        gap: .35rem;
        padding: .28rem .65rem;
    }

    .run-chip.is-terminal-failed {
        background: #fff3f3;
        border-color: #f1aeb5;
        color: #842029;
    }

    .run-chip.is-terminal-completed {
        background: #f0fff4;
        border-color: #badbcc;
        color: #146c43;
    }

    .run-chip.is-terminal-running {
        background: #f2f7ff;
        border-color: #9ec5fe;
        color: #084298;
    }

    .trail-view-switch .nav-link {
        border-radius: 999px;
        color: #475569;
        font-weight: 600;
        padding: .45rem .95rem;
    }

    .trail-view-switch .nav-link.active {
        background: #0f172a;
        color: #fff;
    }

    @@media (max-width: 767.98px) {
        .trail-overview { grid-template-columns: 1fr 1fr; }
        .step-meta span { white-space: normal; }
    }
</style>

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/ops/workflows">Instances</a></li>
        <li class="breadcrumb-item active">Details</li>
    </ol>
</nav>

@if (TempData["SuccessMessage"] is string ok)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @ok
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] is string err)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @err
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (Model.LoadError is not null)
{
    <div class="alert alert-warning">@Model.LoadError</div>
}
else if (inst is not null)
{
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h1 class="h3 mb-1">
                @inst.WorkflowKey
                <span class="badge bg-light text-dark border ms-1 fs-6">@($"v{inst.WorkflowVersion}")</span>
                @Html.Raw(StatusBadge(inst.Status))
            </h1>
            <p class="text-muted mb-0 font-monospace small">@inst.Id</p>
        </div>

        <div class="d-flex gap-2">
            @if (canRetry)
            {
                <form method="post" asp-page-handler="Retry" asp-route-id="@inst.Id">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-warning btn-sm">Retry Failed Step</button>
                </form>
            }
            @if (canReplay)
            {
                <form method="post" asp-page-handler="Replay" asp-route-id="@inst.Id">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-primary btn-sm">Replay from Step 1</button>
                </form>
            }
            @if (canCancel)
            {
                <form method="post" asp-page-handler="Cancel" asp-route-id="@inst.Id">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger btn-sm">Cancel</button>
                </form>
            }
            @if (canArchive)
            {
                <form method="post" asp-page-handler="Archive" asp-route-id="@inst.Id">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-secondary btn-sm">Archive</button>
                </form>
            }
            @if (isArchived)
            {
                <span class="badge bg-light text-secondary border px-3 py-2">Archived - read only</span>
            }
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header fw-semibold small py-2">General Information</div>
                <div class="card-body py-2">
                    <dl class="row mb-0 small">
                        <dt class="col-sm-4 text-muted">Instance ID</dt>
                        <dd class="col-sm-8 font-monospace">@inst.Id</dd>
                        <dt class="col-sm-4 text-muted">Status</dt>
                        <dd class="col-sm-8">@Html.Raw(StatusBadge(inst.Status))</dd>
                        <dt class="col-sm-4 text-muted">Trigger</dt>
                        <dd class="col-sm-8">@Html.Raw(TriggerBadge(inst.TriggerType))</dd>
                        <dt class="col-sm-4 text-muted">External Key</dt>
                        <dd class="col-sm-8">@(inst.ExternalKey ?? "-")</dd>
                        <dt class="col-sm-4 text-muted">Idempotency Key</dt>
                        <dd class="col-sm-8">@(inst.IdempotencyKey ?? "-")</dd>
                        <dt class="col-sm-4 text-muted">Created At</dt>
                        <dd class="col-sm-8">@FormatUtc(inst.CreatedAt)</dd>
                        <dt class="col-sm-4 text-muted">Updated At</dt>
                        <dd class="col-sm-8">@FormatUtc(inst.UpdatedAt)</dd>
                        @if (inst.CompletedAt.HasValue)
                        {
                            <dt class="col-sm-4 text-muted">Completed At</dt>
                            <dd class="col-sm-8">
                                @FormatUtc(inst.CompletedAt.Value)
                                <span class="text-muted ms-1">(@FormatDuration(inst.CompletedAt.Value - inst.CreatedAt))</span>
                            </dd>
                        }
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header fw-semibold small py-2">Input / Trigger Data</div>
                <div class="card-body py-2">
                    <p class="text-muted small mb-1 fw-semibold">Mapped Input</p>
                    @if (string.IsNullOrWhiteSpace(inst.Input))
                    {
                        <p class="text-muted small fst-italic mb-1">No input.</p>
                    }
                    else
                    {
                        <div class="data-box" style="min-height:200px">@PrettyJson(inst.Input)</div>
                    }

                    @if (!string.IsNullOrWhiteSpace(inst.TriggerData))
                    {
                        <details class="mt-2">
                            <summary class="text-muted small fw-semibold" style="cursor:pointer">Raw Trigger Data</summary>
                            <div class="data-box mt-1">@PrettyJson(inst.TriggerData)</div>
                        </details>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (trail?.ReplayEvents.Count > 0)
    {
        <div class="alert alert-info small py-2 mb-3">
            @foreach (var replay in trail.ReplayEvents)
            {
                <div>Replayed at @FormatUtc(replay.OccurredAt)</div>
            }
        </div>
    }

    @if (trail is not null && trail.Steps.Count > 0)
    {
        <div class="trail-overview mb-3">
            <div class="trail-stat">
                <span class="trail-stat-label">Steps</span>
                <span class="trail-stat-value">@totalSteps</span>
            </div>
            <div class="trail-stat">
                <span class="trail-stat-label">Completed</span>
                <span class="trail-stat-value">@completedSteps</span>
            </div>
            <div class="trail-stat">
                <span class="trail-stat-label">In Flight</span>
                <span class="trail-stat-value">@activeSteps</span>
            </div>
            <div class="trail-stat">
                <span class="trail-stat-label">Failed</span>
                <span class="trail-stat-value">@failedSteps</span>
            </div>
            <div class="trail-stat">
                <span class="trail-stat-label">Retried</span>
                <span class="trail-stat-value">@retriedSteps</span>
            </div>
        </div>

        @if (focusStep is not null)
        {
            <div class="trail-focus @FocusPanelClass(focusStep.LatestStatus) mb-4">
                <div class="trail-focus-kicker">@FocusHeading(inst.Status, focusStep)</div>
                <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                    <div>
                        <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                            <span class="fw-semibold">@focusStep.StepKey</span>
                            <span class="badge bg-light text-dark border">@focusStep.StepType</span>
                            @Html.Raw(StepStatusBadge(focusStep.LatestStatus))
                            @if (!string.IsNullOrWhiteSpace(focusStep.LatestFailureClassification))
                            {
                                @Html.Raw(ClassificationBadge(focusStep.LatestFailureClassification))
                            }
                            @if (focusStep.Attempts.Count > 1)
                            {
                                <span class="badge bg-warning text-dark">@($"{focusStep.Attempts.Count} runs")</span>
                            }
                        </div>
                        <div class="trail-subtitle">This keeps the most relevant step visible immediately without making the full trail feel heavy.</div>
                    </div>

                    @if (focusAttempt is not null)
                    {
                        <div class="text-muted small">
                            <div><strong>Scheduled:</strong> @FormatUtc(focusAttempt.ScheduledAt)</div>
                            <div><strong>Started:</strong> @(focusAttempt.StartedAt.HasValue ? FormatUtc(focusAttempt.StartedAt.Value) : "-")</div>
                            <div><strong>Completed:</strong> @(focusAttempt.CompletedAt.HasValue ? FormatUtc(focusAttempt.CompletedAt.Value) : "-")</div>
                            <div><strong>Duration:</strong> @AttemptDuration(focusAttempt)</div>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(focusStep.LatestError))
                {
                    <div class="err-box">@focusStep.LatestError</div>
                }

                <div class="step-signals">
                    @if (focusStep.NextRetryAt.HasValue)
                    {
                        <span class="signal-pill retry">Retry scheduled for @FormatUtc(focusStep.NextRetryAt.Value)</span>
                    }
                    @if (focusStep.WaitingUntil.HasValue)
                    {
                        <span class="signal-pill wait">Waiting until @FormatUtc(focusStep.WaitingUntil.Value)</span>
                    }
                </div>
            </div>
        }
    }

    @if (!hasTrailData)
    {
        <p class="text-muted mt-4">No step executions recorded yet.</p>
    }
    else
    {
        <div class="mt-4">
            <ul class="nav nav-pills trail-view-switch mb-3" id="execution-view-tabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active"
                            id="workflow-runs-tab"
                            data-bs-toggle="pill"
                            data-bs-target="#workflow-runs-pane"
                            type="button"
                            role="tab"
                            aria-controls="workflow-runs-pane"
                            aria-selected="true">
                        Workflow Runs
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link"
                            id="step-trail-tab"
                            data-bs-toggle="pill"
                            data-bs-target="#step-trail-pane"
                            type="button"
                            role="tab"
                            aria-controls="step-trail-pane"
                            aria-selected="false">
                        Step Trail
                    </button>
                </li>
            </ul>

            <div class="tab-content">
                <div class="tab-pane fade show active"
                     id="workflow-runs-pane"
                     role="tabpanel"
                     aria-labelledby="workflow-runs-tab"
                     tabindex="0">
                    <div class="d-flex justify-content-between align-items-end mb-2">
                        <div>
                            <h5 class="fw-semibold mb-1">Workflow Runs</h5>
                            <div class="trail-subtitle">See each workflow run from the instance perspective, including where it resumed and where it stopped.</div>
                        </div>
                    </div>

                    <div class="run-perspective">
                        @foreach (var run in workflowRuns)
                        {
                            <div class="run-card @RunCardClass(run.FinalStatus)">
                                <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                                    <div>
                                        <div class="d-flex align-items-center gap-2 flex-wrap">
                                            <span class="fw-semibold">Run @run.RunNumber</span>
                                            @Html.Raw(StepStatusBadge(run.FinalStatus))
                                            @if (!string.IsNullOrWhiteSpace(run.FinalFailureClassification))
                                            {
                                                @Html.Raw(ClassificationBadge(run.FinalFailureClassification))
                                            }
                                        </div>
                                        <div class="text-muted small mt-1">@run.KindLabel</div>
                                    </div>

                                    <div class="run-meta small">
                                        <span><strong>Started from:</strong> @run.StartedFromStep</span>
                                        <span><strong>Stopped at:</strong> @run.EndedAtStep</span>
                                        <span><strong>Started:</strong> @FormatUtc(run.StartedAt)</span>
                                        <span><strong>Ended:</strong> @(run.CompletedAt.HasValue ? FormatUtc(run.CompletedAt.Value) : "-")</span>
                                        <span><strong>Duration:</strong> @RunDuration(run)</span>
                                    </div>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(run.FinalError))
                                {
                                    <div class="err-box">@run.FinalError</div>
                                }

                                <div class="run-sequence">
                                    @foreach (var stepView in run.Steps)
                                    {
                                        var isTerminal = stepView == run.Steps[^1];
                                        <span class="run-chip @(isTerminal ? RunChipClass(stepView.Status) : string.Empty)">
                                            <span>@stepView.StepKey</span>
                                            <span class="text-muted">@stepView.StepOrder</span>
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="tab-pane fade"
                     id="step-trail-pane"
                     role="tabpanel"
                     aria-labelledby="step-trail-tab"
                     tabindex="0">
                    <div class="d-flex justify-content-between align-items-end mb-2">
                        <div>
                            <h5 class="fw-semibold mb-1">Step Trail</h5>
                            <div class="trail-subtitle">Execution timeline with details where things need attention.</div>
                        </div>
                    </div>

                    @foreach (var step in trail!.Steps)
                    {
                        var isFailed = step.LatestStatus == "Failed";
                        var hasRetries = step.Attempts.Count > 1;
                        var isActive = step.LatestStatus is "Running" or "Waiting" or "Pending";
                        var expand = isFailed || hasRetries || isActive;
                        var last = step.Attempts.Count > 0 ? step.Attempts[^1] : null;

                        var icon = step.LatestStatus switch
                        {
                            "Completed" => ("ok", "&#10003;"),
                            "Failed" => ("err", "&#10007;"),
                            "Running" => ("run", "&#9654;"),
                            _ => ("wait", step.StepOrder.ToString())
                        };

                        <div class="step-row">
                            <div class="step-icon @icon.Item1">@Html.Raw(icon.Item2)</div>

                            <div class="step-shell @StepShellClass(isFailed, isActive, hasRetries)">
                                <div class="d-flex align-items-center gap-2 flex-wrap">
                                    <span class="fw-semibold">@step.StepKey</span>
                                    <span class="badge bg-light text-dark border">@step.StepType</span>
                                    @Html.Raw(StepStatusBadge(step.LatestStatus))
                                    @if (!string.IsNullOrWhiteSpace(step.LatestFailureClassification))
                                    {
                                        @Html.Raw(ClassificationBadge(step.LatestFailureClassification))
                                    }
                                    @if (hasRetries)
                                    {
                                        <span class="badge bg-warning text-dark">@($"{step.Attempts.Count} runs")</span>
                                    }
                                    @if (last?.StartedAt is not null && last?.CompletedAt is not null)
                                    {
                                        <span class="text-muted small ms-auto">@FormatDuration(last.CompletedAt.Value - last.StartedAt.Value)</span>
                                    }
                                </div>

                                <div class="step-meta small">
                                    <span><strong>Scheduled:</strong> @(last is null ? "-" : FormatUtc(last.ScheduledAt))</span>
                                    <span><strong>Started:</strong> @(last?.StartedAt is null ? "-" : FormatUtc(last.StartedAt.Value))</span>
                                    <span><strong>Completed:</strong> @(last?.CompletedAt is null ? "-" : FormatUtc(last.CompletedAt.Value))</span>
                                </div>

                                @if (step.NextRetryAt.HasValue || step.WaitingUntil.HasValue)
                                {
                                    <div class="step-signals">
                                        @if (step.NextRetryAt.HasValue)
                                        {
                                            <span class="signal-pill retry">Retry at @FormatUtc(step.NextRetryAt.Value)</span>
                                        }
                                        @if (step.WaitingUntil.HasValue)
                                        {
                                            <span class="signal-pill wait">Waiting until @FormatUtc(step.WaitingUntil.Value)</span>
                                        }
                                    </div>
                                }

                                @if (!expand)
                                {
                                    if (!string.IsNullOrWhiteSpace(step.LatestOutput))
                                    {
                                        <details class="mt-2">
                                            <summary class="text-muted small" style="cursor:pointer">Output</summary>
                                            <div class="data-box mt-1">@PrettyJson(step.LatestOutput)</div>
                                        </details>
                                    }
                                }
                                else
                                {
                                    @if (!string.IsNullOrWhiteSpace(step.LatestError))
                                    {
                                        <div class="err-box">@step.LatestError</div>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(step.LatestInput))
                                    {
                                        <details class="mt-2">
                                            <summary class="text-muted small fw-semibold" style="cursor:pointer">Latest Input</summary>
                                            <div class="data-box mt-1">@PrettyJson(step.LatestInput)</div>
                                        </details>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(step.LatestOutput))
                                    {
                                        @if (isFailed)
                                        {
                                            <details class="mt-2" open>
                                                <summary class="text-muted small fw-semibold" style="cursor:pointer">Latest Output</summary>
                                                <div class="data-box mt-1">@PrettyJson(step.LatestOutput)</div>
                                            </details>
                                        }
                                        else
                                        {
                                            <details class="mt-2">
                                                <summary class="text-muted small fw-semibold" style="cursor:pointer">Latest Output</summary>
                                                <div class="data-box mt-1">@PrettyJson(step.LatestOutput)</div>
                                            </details>
                                        }
                                    }

                                    @if (hasRetries)
                                    {
                                        <div class="mt-3">
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <p class="text-muted small fw-semibold mb-0">Run History</p>
                                            </div>

                                            <table class="table table-sm small mb-0">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>#</th>
                                                        <th>Status</th>
                                                        <th>Started</th>
                                                        <th>Duration</th>
                                                        <th>Error</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @for (var runIndex = 0; runIndex < step.Attempts.Count; runIndex++)
                                                    {
                                                        var attempt = step.Attempts[runIndex];
                                                        var rowClass = attempt.Status switch
                                                        {
                                                            "Completed" => "table-success",
                                                            "Failed" => "table-danger",
                                                            "Running" => "table-primary",
                                                            _ => ""
                                                        };

                                                        <tr class="@rowClass">
                                                            <td>
                                                                <div class="fw-semibold">@(runIndex + 1)</div>
                                                            </td>
                                                            <td>@Html.Raw(StepStatusBadge(attempt.Status))</td>
                                                            <td class="text-muted">@(attempt.StartedAt?.ToString("HH:mm:ss' UTC'") ?? "-")</td>
                                                            <td class="text-muted">@AttemptDurationShort(attempt)</td>
                                                            <td>
                                                                @if (!string.IsNullOrWhiteSpace(attempt.Error))
                                                                {
                                                                    <span class="text-danger" title="@attempt.Error">@Truncate(attempt.Error, 90)</span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="text-muted">-</span>
                                                                }
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @if (inst.Status == "AwaitingRetry")
    {
        <div class="alert alert-warning mt-3 small">
            This workflow is waiting for a retry to be picked up by a worker.
        </div>
    }
}
