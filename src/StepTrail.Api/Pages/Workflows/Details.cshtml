@page "/ops/workflows/details"
@model StepTrail.Api.Pages.Workflows.DetailsModel
@{
    ViewData["Title"] = Model.Instance is null ? "Instance Not Found" : $"Instance {Model.Id.ToString()[..8]}…";
    var inst = Model.Instance;
    bool isFailed    = inst?.Status == "Failed";
    bool isCompleted = inst?.Status == "Completed";
    bool isCancelled = inst?.Status == "Cancelled";
    bool isArchived  = inst?.Status == "Archived";
    bool isRunning   = inst?.Status == "Running";
    bool canRetry    = isFailed;
    bool canReplay   = isFailed || isCompleted;
    bool canCancel   = inst is not null && !isCompleted && !isCancelled && !isArchived;
    bool canArchive  = inst is not null && !isRunning && !isArchived;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/ops/workflows">Workflow Instances</a></li>
        <li class="breadcrumb-item active">Details</li>
    </ol>
</nav>

@* Feedback alerts *@
@if (TempData["SuccessMessage"] is string ok)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @ok
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] is string err)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @err
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (Model.LoadError is not null)
{
    <div class="alert alert-warning">@Model.LoadError</div>
}
else if (inst is not null)
{
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-1">
                @inst.WorkflowKey
                <span class="badge bg-light text-dark border ms-1 fs-6">v@inst.WorkflowVersion</span>
                @Html.Raw(StatusBadge(inst.Status))
            </h1>
            <p class="text-muted mb-0 font-monospace small">@inst.Id</p>
        </div>

        @* Action buttons *@
        <div class="d-flex gap-2">
            @if (canRetry)
            {
                <form method="post" asp-page-handler="Retry" asp-route-id="@inst.Id">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-warning btn-sm">Retry Failed Step</button>
                </form>
            }
            @if (canReplay)
            {
                <form method="post" asp-page-handler="Replay" asp-route-id="@inst.Id">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-primary btn-sm">Replay from Step 1</button>
                </form>
            }
            @if (canCancel)
            {
                <form method="post" asp-page-handler="Cancel" asp-route-id="@inst.Id">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger btn-sm">Cancel</button>
                </form>
            }
            @if (canArchive)
            {
                <form method="post" asp-page-handler="Archive" asp-route-id="@inst.Id">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-secondary btn-sm">Archive</button>
                </form>
            }
            @if (isArchived)
            {
                <span class="badge bg-light text-secondary border px-3 py-2">Archived — read only</span>
            }
        </div>
    </div>

    <div class="row g-3 mb-4">

        @* General information *@
        <div class="col-md-6">
            <div class="card h-100 shadow-sm">
                <div class="card-header fw-semibold">General Information</div>
                <div class="card-body">
                    <dl class="row mb-0 small">
                        <dt class="col-sm-4 text-muted">Instance ID</dt>
                        <dd class="col-sm-8 font-monospace">@inst.Id</dd>

                        <dt class="col-sm-4 text-muted">External Key</dt>
                        <dd class="col-sm-8">@(inst.ExternalKey ?? "—")</dd>

                        <dt class="col-sm-4 text-muted">Idempotency Key</dt>
                        <dd class="col-sm-8">@(inst.IdempotencyKey ?? "—")</dd>

                        <dt class="col-sm-4 text-muted">Status</dt>
                        <dd class="col-sm-8">@Html.Raw(StatusBadge(inst.Status))</dd>

                        <dt class="col-sm-4 text-muted">Created At</dt>
                        <dd class="col-sm-8">@inst.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss zzz")</dd>

                        <dt class="col-sm-4 text-muted">Updated At</dt>
                        <dd class="col-sm-8">@inst.UpdatedAt.ToString("yyyy-MM-dd HH:mm:ss zzz")</dd>

                        <dt class="col-sm-4 text-muted">Completed At</dt>
                        <dd class="col-sm-8">@(inst.CompletedAt?.ToString("yyyy-MM-dd HH:mm:ss zzz") ?? "—")</dd>
                    </dl>
                </div>
            </div>
        </div>

        @* Input / output + error *@
        <div class="col-md-6">
            <div class="card h-100 shadow-sm">
                <div class="card-header fw-semibold">Input / Output</div>
                <div class="card-body">
                    <p class="text-muted small mb-1 fw-semibold">Input</p>
                    @if (string.IsNullOrWhiteSpace(inst.Input))
                    {
                        <p class="text-muted small fst-italic">No input.</p>
                    }
                    else
                    {
                        <pre class="json-block">@inst.Input</pre>
                    }

                    @{
                        var lastOutput = inst.StepExecutions
                            .Where(s => s.Status == "Completed" && s.Output is not null)
                            .OrderByDescending(s => s.CompletedAt)
                            .Select(s => s.Output)
                            .FirstOrDefault();

                        var errorStep = inst.StepExecutions
                            .Where(s => s.Status == "Failed" && s.Error is not null)
                            .OrderByDescending(s => s.CompletedAt)
                            .FirstOrDefault();
                    }

                    <p class="text-muted small mb-1 fw-semibold mt-3">Last Output</p>
                    @if (string.IsNullOrWhiteSpace(lastOutput))
                    {
                        <p class="text-muted small fst-italic">No output yet.</p>
                    }
                    else
                    {
                        <pre class="json-block">@lastOutput</pre>
                    }

                    @if (errorStep is not null)
                    {
                        <div class="alert alert-danger small mt-3 mb-0 py-2">
                            <strong>Error in step "@errorStep.StepKey" (attempt @errorStep.Attempt):</strong><br />
                            @errorStep.Error
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @* Step execution timeline *@
    <div class="card shadow-sm">
        <div class="card-header fw-semibold">Step Execution Timeline</div>
        <div class="card-body p-0">
            @if (!inst.StepExecutions.Any())
            {
                <p class="text-muted p-3 mb-0">No step executions recorded yet.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Step</th>
                                <th>Status</th>
                                <th>Attempt</th>
                                <th>Scheduled At</th>
                                <th>Started At</th>
                                <th>Completed At</th>
                                <th>Error</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var step in inst.StepExecutions)
                            {
                                var rowClass = step.Status switch
                                {
                                    "Completed" => "table-success",
                                    "Failed"    => "table-danger",
                                    "Running"   => "table-primary",
                                    "Cancelled" => "table-warning",
                                    _           => ""
                                };
                                <tr class="@rowClass">
                                    <td class="fw-semibold small">@step.StepKey</td>
                                    <td>@Html.Raw(StepStatusBadge(step.Status))</td>
                                    <td class="text-center">@step.Attempt</td>
                                    <td class="text-muted small">@step.ScheduledAt.ToString("HH:mm:ss")</td>
                                    <td class="text-muted small">@(step.StartedAt?.ToString("HH:mm:ss") ?? "—")</td>
                                    <td class="text-muted small">@(step.CompletedAt?.ToString("HH:mm:ss") ?? "—")</td>
                                    <td class="text-danger small">
                                        @if (!string.IsNullOrWhiteSpace(step.Error))
                                        {
                                            <span title="@step.Error">@TruncateError(step.Error, 80)</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@* Bootstrap JS for dismissible alerts *@
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmK0xNnfkEbw9tGJKh7AqFHQS"
        crossorigin="anonymous"></script>

@functions {
    static string StatusBadge(string status) => status switch
    {
        "Pending"   => "<span class=\"badge bg-secondary\">Pending</span>",
        "Running"   => "<span class=\"badge bg-primary\">Running</span>",
        "Completed" => "<span class=\"badge bg-success\">Completed</span>",
        "Failed"    => "<span class=\"badge bg-danger\">Failed</span>",
        "Cancelled" => "<span class=\"badge bg-warning text-dark\">Cancelled</span>",
        "Archived"  => "<span class=\"badge bg-light text-secondary border\">Archived</span>",
        _           => $"<span class=\"badge bg-light text-dark\">{status}</span>"
    };

    static string StepStatusBadge(string status) => status switch
    {
        "Pending"   => "<span class=\"badge bg-secondary\">Pending</span>",
        "Running"   => "<span class=\"badge bg-primary\">Running</span>",
        "Completed" => "<span class=\"badge bg-success\">Completed</span>",
        "Failed"    => "<span class=\"badge bg-danger\">Failed</span>",
        "Cancelled" => "<span class=\"badge bg-warning text-dark\">Cancelled</span>",
        "Archived"  => "<span class=\"badge bg-light text-secondary border\">Archived</span>",
        _           => $"<span class=\"badge bg-light text-dark\">{status}</span>"
    };

    static string TruncateError(string error, int max) =>
        error.Length <= max ? error : error[..max] + "…";
}
