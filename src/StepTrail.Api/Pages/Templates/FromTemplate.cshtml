@page "/ops/definitions/from-template"
@model StepTrail.Api.Pages.Templates.FromTemplateModel
@{
    ViewData["Title"] = "New Workflow from Template";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/ops/templates">Templates</a></li>
        <li class="breadcrumb-item active">Use Template</li>
    </ol>
</nav>

<div class="row justify-content-center">
    <div class="col-lg-7">

        @if (Model.LoadError is not null)
        {
            <div class="alert alert-warning">@Model.LoadError</div>
        }
        else if (Model.Template is not null)
        {
            @* Template summary *@
            <div class="card shadow-sm mb-4">
                <div class="card-header fw-semibold d-flex align-items-center justify-content-between">
                    <span>Template: @Model.Template.Name</span>
                    <span class="badge bg-light text-dark border">v@Model.Template.Version</span>
                </div>
                <div class="card-body">
                    <p class="font-monospace text-muted small mb-2">@Model.Template.Key</p>
                    @if (!string.IsNullOrWhiteSpace(Model.Template.Description))
                    {
                        <p class="text-muted small mb-2">@Model.Template.Description</p>
                    }
                    <div class="small border-top pt-2 mb-1">
                        <span class="fw-semibold text-muted">Trigger:</span>
                        @Html.Raw(TriggerBadge(Model.Template.TriggerType))
                    </div>
                    @if (Model.Template.Steps.Count > 0)
                    {
                        <div class="small">
                            <span class="fw-semibold text-muted">Steps:</span>
                            @foreach (var step in Model.Template.Steps.OrderBy(s => s.Order))
                            {
                                <span class="ms-1 badge bg-light text-dark border">
                                    #@step.Order @step.StepKey
                                    <span class="text-muted">(@StepTypeLabel(step.StepType))</span>
                                </span>
                            }
                        </div>
                    }
                    <div class="mt-2">
                        <a href="/ops/templates" class="text-muted small">View full template details</a>
                    </div>
                </div>
            </div>

            @* Create form — name and key only *@
            <div class="card shadow-sm">
                <div class="card-header fw-semibold">New Workflow</div>
                <div class="card-body">

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger py-2 small">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div>@error.ErrorMessage</div>
                            }
                        </div>
                    }

                    <form method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="DescriptorKey" value="@Model.DescriptorKey" />
                        <input type="hidden" name="DescriptorVersion" value="@Model.DescriptorVersion" />

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Workflow Name</label>
                            <input name="Name" type="text" class="form-control"
                                   value="@Model.Name" required autofocus />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Workflow Key</label>
                            <input name="Key" type="text" class="form-control font-monospace"
                                   value="@Model.Key" required
                                   pattern="[a-z0-9][a-z0-9\-]*[a-z0-9]"
                                   title="Lowercase letters, numbers, and hyphens." />
                            <div class="form-text">Stable identifier. Cannot be changed after creation.</div>
                        </div>

                        <p class="text-muted small mb-0">
                            Trigger and step configuration from the template will be pre-populated. You can edit them after creation.
                        </p>

                        <div class="d-flex gap-2 mt-3">
                            <button type="submit" class="btn btn-primary">Create Workflow</button>
                            <a href="/ops/templates" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        }

    </div>
</div>

@functions {
    static string TriggerBadge(string? triggerType) => triggerType switch
    {
        "Webhook"  => "<span class=\"badge bg-info text-dark\">Webhook</span>",
        "Manual"   => "<span class=\"badge bg-secondary\">Manual</span>",
        "Schedule" => "<span class=\"badge bg-warning text-dark\">Schedule</span>",
        _          => "<span class=\"badge bg-light text-dark border\">Unknown</span>"
    };

    static string StepTypeLabel(string stepType) => stepType switch
    {
        "HttpRequest" or "HttpActivityHandler" => "HTTP",
        "SendWebhook" or "SendWebhookStepExecutor" => "Webhook",
        "Transform" or "TransformStepExecutor" => "Transform",
        "Conditional" or "ConditionalStepExecutor" => "Conditional",
        "Delay" or "DelayStepExecutor" => "Delay",
        _ => stepType
    };
}
