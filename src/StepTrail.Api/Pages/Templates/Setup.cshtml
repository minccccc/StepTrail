@page "/ops/definitions/setup"
@model StepTrail.Api.Pages.Templates.SetupModel
@{
    ViewData["Title"] = "Set Up: Webhook → HTTP Call";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/ops/definitions">Templates</a></li>
        <li class="breadcrumb-item active">Webhook → HTTP Call</li>
    </ol>
</nav>

<div class="row justify-content-center">
    <div class="col-lg-7">

        <div class="card shadow-sm mb-4">
            <div class="card-header fw-semibold">How it works</div>
            <div class="card-body small text-muted">
                <ol class="mb-0 ps-3">
                    <li>An external system calls <code>POST /webhooks/webhook-to-http-call</code> with a JSON payload.</li>
                    <li>StepTrail starts a workflow instance and queues the HTTP call step.</li>
                    <li>The worker forwards the payload to your <strong>Target URL</strong>.</li>
                    <li>On non-2xx response the step retries up to 3&nbsp;times (30&nbsp;s delay). After that an alert is fired.</li>
                </ol>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header fw-semibold">Configure &amp; Run</div>
            <div class="card-body">

                @if (Model.ErrorMessage is not null)
                {
                    <div class="alert alert-danger py-2 small">@Model.ErrorMessage</div>
                }

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2 small">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    </div>
                }

                <form method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold" for="TargetUrl">Target URL</label>
                        <input id="TargetUrl" name="TargetUrl" type="url"
                               class="form-control font-monospace"
                               placeholder="https://api.example.com/ingest"
                               value="@Model.TargetUrl"
                               autofocus required />
                        <div class="form-text">
                            The endpoint that receives the forwarded webhook payload.
                            Stored as the <code>webhook-to-http-call-url</code> secret — update it anytime from the Secrets page.
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">Save &amp; Run Now</button>
                        <a href="/ops/definitions" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>
