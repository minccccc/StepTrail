@page "/ops/definitions/new"
@model StepTrail.Api.Pages.Templates.NewModel
@{
    ViewData["Title"] = "New Workflow";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/ops/definitions">Workflows</a></li>
        <li class="breadcrumb-item active">New Workflow</li>
    </ol>
</nav>

<h1 class="h3 mb-4">New Workflow</h1>

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger py-2 small">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div>@error.ErrorMessage</div>
        }
    </div>
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm mb-4">
            <div class="card-header fw-semibold">Create Manually</div>
            <div class="card-body">
                <p class="text-muted small mb-3">
                    Start with a blank workflow. Choose a trigger type and add steps from scratch.
                </p>
                <form method="post" asp-page-handler="CreateBlank">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Workflow Name</label>
                        <input name="BlankName" type="text" class="form-control"
                               value="@Model.BlankName" placeholder="My Workflow" required autofocus />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Workflow Key</label>
                        <input name="BlankKey" type="text" class="form-control font-monospace"
                               value="@Model.BlankKey" placeholder="my-workflow" required
                               pattern="[a-z0-9][a-z0-9\-]*[a-z0-9]"
                               title="Lowercase letters, numbers, and hyphens." />
                        <div class="form-text">Stable identifier. Cannot be changed after creation.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Trigger Type</label>
                        <select name="BlankTriggerType" class="form-select">
                            @foreach (var t in NewModel.TriggerTypes)
                            {
                                <option value="@t" selected="@(Model.BlankTriggerType == t)">@t</option>
                            }
                        </select>
                        <div class="form-text">How this workflow will be started. You can change this later in the editor.</div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">Create Workflow</button>
                        <a href="/ops/definitions" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>

        <p class="text-muted small text-center">
            Or <a href="/ops/templates">browse templates</a> to create a workflow from a predefined blueprint.
        </p>
    </div>
</div>
