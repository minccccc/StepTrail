@page "/ops/definitions"
@model StepTrail.Api.Pages.Templates.IndexModel
@{
    ViewData["Title"] = "Workflows";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0">Workflows</h1>
    <div class="d-flex align-items-center gap-2">
        <span class="text-muted small">@Model.Definitions.Count workflow(s)</span>
        <a href="/ops/templates" class="btn btn-sm btn-outline-primary">From Template</a>
        <a href="/ops/definitions/new" class="btn btn-sm btn-primary">+ New Workflow</a>
    </div>
</div>

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}
else if (!Model.Definitions.Any())
{
    <div class="alert alert-secondary">
        <strong>No workflow definitions yet.</strong>
        <div class="mt-2">
            <a href="/ops/templates">Browse templates</a> to start from a predefined blueprint,
            or <a href="/ops/definitions/new">create one manually</a>.
            <a href="/ops/getting-started" class="ms-2">Getting Started guide</a>
        </div>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover table-sm align-middle bg-white shadow-sm rounded">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Key</th>
                    <th>Source</th>
                    <th>Trigger</th>
                    <th>Status</th>
                    <th>Version</th>
                    <th>Steps</th>
                    <th>Updated</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var def in Model.Definitions)
                {
                    <tr>
                        <td class="fw-semibold">
                            @def.Name
                            @if (!string.IsNullOrWhiteSpace(def.Description))
                            {
                                <br /><span class="text-muted small">@Truncate(def.Description, 80)</span>
                            }
                        </td>
                        <td class="font-monospace small">@def.Key</td>
                        <td class="small">
                            @if (!string.IsNullOrWhiteSpace(def.SourceTemplateKey))
                            {
                                <span class="badge bg-info text-dark" title="From template: @def.SourceTemplateKey v@def.SourceTemplateVersion">Template</span>
                            }
                            else
                            {
                                <span class="badge bg-light text-muted border">Manual</span>
                            }
                        </td>
                        <td>@Html.Raw(TriggerBadge(def.TriggerType))</td>
                        <td>@Html.Raw(StatusBadge(def.Status))</td>
                        <td class="text-center">
                            <span class="badge bg-light text-dark border">v@def.Version</span>
                        </td>
                        <td class="text-center text-muted">@def.StepCount</td>
                        <td class="text-muted small">@def.UpdatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="d-flex gap-1">
                            <a href="/ops/definitions/edit?id=@def.Id"
                               class="btn btn-sm btn-outline-secondary">Edit</a>
                            <a href="/ops/definitions/create?templateId=@def.Id"
                               class="btn btn-sm btn-outline-secondary" title="Clone this workflow">Clone</a>
                            <a href="/ops/workflows?workflowKey=@Uri.EscapeDataString(def.Key)"
                               class="btn btn-sm btn-outline-primary">
                                Instances
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@functions {
    static string StatusBadge(string status) => status switch
    {
        "Active"   => "<span class=\"badge bg-success\">Active</span>",
        "Inactive" => "<span class=\"badge bg-secondary\">Inactive</span>",
        "Draft"    => "<span class=\"badge bg-light text-dark border\">Draft</span>",
        _          => $"<span class=\"badge bg-light text-dark\">{status}</span>"
    };

    static string TriggerBadge(string? triggerType) => triggerType switch
    {
        "Webhook"  => "<span class=\"badge bg-info text-dark\">Webhook</span>",
        "Manual"   => "<span class=\"badge bg-secondary\">Manual</span>",
        "Api"      => "<span class=\"badge bg-primary\">API</span>",
        "Schedule" => "<span class=\"badge bg-warning text-dark\">Schedule</span>",
        _          => "<span class=\"badge bg-light text-dark border\">Unknown</span>"
    };

    static string Truncate(string text, int max) =>
        text.Length <= max ? text : text[..max] + "...";
}
