@page "/ops/templates"
@model StepTrail.Api.Pages.Templates.CatalogModel
@{
    ViewData["Title"] = "Templates";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="h3 mb-1">Templates</h1>
        <p class="text-muted mb-0 small">
            Predefined workflow blueprints. Review the default configuration, then pick a template to create a new workflow.
        </p>
    </div>
    <span class="text-muted small">@Model.Templates.Count template(s)</span>
</div>

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}
else if (!Model.Templates.Any())
{
    <div class="alert alert-secondary">
        <strong>No templates available.</strong> Templates are predefined workflow blueprints registered in code.
        <div class="mt-2">
            You can still <a href="/ops/definitions/new">create a workflow manually</a> from scratch.
            <a href="/ops/getting-started" class="ms-2">Getting Started guide</a>
        </div>
    </div>
}
else
{
    @foreach (var template in Model.Templates)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header d-flex align-items-center justify-content-between">
                <div>
                    <span class="fw-semibold fs-5">@template.Name</span>
                    <span class="badge bg-light text-dark border ms-2">v@template.Version</span>
                    @Html.Raw(TriggerBadge(template.TriggerType))
                    <span class="badge bg-light text-muted border ms-1">@template.Steps.Count step(s)</span>
                    @if (template.RecurrenceIntervalSeconds.HasValue)
                    {
                        <span class="badge bg-warning text-dark ms-1" title="Runs every @template.RecurrenceIntervalSeconds seconds">
                            Recurring: every @FormatInterval(template.RecurrenceIntervalSeconds.Value)
                        </span>
                    }
                </div>
                <a href="/ops/definitions/from-template?descriptorKey=@Uri.EscapeDataString(template.Key)&descriptorVersion=@template.Version"
                   class="btn btn-primary btn-sm">
                    Use Template
                </a>
            </div>
            <div class="card-body">
                <p class="font-monospace text-muted small mb-2">@template.Key</p>
                @if (!string.IsNullOrWhiteSpace(template.Description))
                {
                    <p class="text-muted mb-3">@template.Description</p>
                }

                @if (template.Steps.Count > 0)
                {
                    <h6 class="fw-semibold mb-2 mt-3">Steps</h6>
                    @foreach (var step in template.Steps.OrderBy(s => s.Order))
                    {
                        <div class="border rounded p-3 mb-2 bg-light">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <span class="text-muted small fw-semibold">#@step.Order</span>
                                <span class="font-monospace fw-semibold">@step.StepKey</span>
                                @Html.Raw(StepTypeBadge(step.StepType))
                            </div>

                            <div class="row g-2 mt-1 small">
                                <div class="col-auto">
                                    <span class="text-muted">Retry:</span>
                                    <span>@step.MaxAttempts attempts, @step.RetryDelaySeconds s delay</span>
                                </div>
                                @if (step.TimeoutSeconds.HasValue)
                                {
                                    <div class="col-auto">
                                        <span class="text-muted">Timeout:</span>
                                        <span>@step.TimeoutSeconds s</span>
                                    </div>
                                }
                            </div>

                            @if (!string.IsNullOrWhiteSpace(step.Config))
                            {
                                <div class="mt-2">
                                    <span class="text-muted small fw-semibold">Configuration</span>
                                    <pre class="json-block mt-1 mb-0" style="max-height:160px">@FormatJson(step.Config)</pre>
                                </div>
                            }
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted small">No steps defined in this template.</p>
                }
            </div>
        </div>
    }
}

@functions {
    static string TriggerBadge(string? triggerType) => triggerType switch
    {
        "Webhook"  => "<span class=\"badge bg-info text-dark\">Webhook</span>",
        "Manual"   => "<span class=\"badge bg-secondary\">Manual</span>",
        "Schedule" => "<span class=\"badge bg-warning text-dark\">Schedule</span>",
        _          => "<span class=\"badge bg-light text-dark border\">Unknown</span>"
    };

    static string StepTypeBadge(string stepType)
    {
        var (label, css) = stepType switch
        {
            "HttpRequest" or "HttpActivityHandler" => ("HTTP Request", "bg-primary"),
            "SendWebhook" or "SendWebhookStepExecutor" => ("Send Webhook", "bg-info text-dark"),
            "Transform" or "TransformStepExecutor" => ("Transform", "bg-success"),
            "Conditional" or "ConditionalStepExecutor" => ("Conditional", "bg-warning text-dark"),
            "Delay" or "DelayStepExecutor" => ("Delay", "bg-secondary"),
            _ => (stepType, "bg-light text-dark border")
        };
        return $"<span class=\"badge {css}\">{label}</span>";
    }

    static string FormatInterval(int seconds) => seconds switch
    {
        < 60 => $"{seconds}s",
        < 3600 => $"{seconds / 60}m",
        _ => $"{seconds / 3600}h {(seconds % 3600) / 60}m"
    };

    static string FormatJson(string json)
    {
        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(json);
            return System.Text.Json.JsonSerializer.Serialize(
                doc, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return json;
        }
    }
}
