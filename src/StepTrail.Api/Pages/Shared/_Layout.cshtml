<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — StepTrail Ops</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />
    <style>
        body { background-color: #f8f9fa; }
        .navbar-brand { font-weight: 600; letter-spacing: .03em; }
        pre.json-block {
            background: #1e1e1e;
            color: #d4d4d4;
            border-radius: .375rem;
            padding: 1rem;
            font-size: .8rem;
            max-height: 300px;
            overflow-y: auto;
            white-space: pre-wrap;
            word-break: break-all;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container-fluid">
            <a class="navbar-brand" href="/ops/workflows">StepTrail Ops</a>
            <div class="d-flex align-items-center gap-3 me-auto ms-4">
                <a href="/ops/workflows" class="nav-link text-secondary small px-0">Instances</a>
                <a href="/ops/definitions" class="nav-link text-secondary small px-0">Workflows</a>
                <a href="/ops/templates" class="nav-link text-secondary small px-0">Templates</a>
            </div>
            <div class="d-flex align-items-center gap-3">
                <a href="/ops/telemetry" class="nav-link text-secondary small px-0">Telemetry</a>
                <a href="/ops/getting-started" class="nav-link text-secondary small px-0">Getting Started</a>
                <span class="navbar-text text-secondary small">Operations Console</span>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="navbar-text text-light small">@User.Identity.Name</span>
                    <form method="post" action="/logout" class="mb-0">
                        <button type="submit" class="btn btn-sm btn-outline-secondary text-light border-secondary">
                            Sign out
                        </button>
                    </form>
                }
            </div>
        </div>
    </nav>

    <main class="container-fluid px-4">
        @RenderBody()
    </main>

    <footer class="container-fluid px-4 mt-5 pb-3 text-muted small">
        StepTrail &mdash; Internal Operations Console
    </footer>
</body>
</html>
