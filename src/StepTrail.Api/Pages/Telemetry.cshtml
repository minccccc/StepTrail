@page "/ops/telemetry"
@model StepTrail.Api.Pages.TelemetryModel
@{
    ViewData["Title"] = "Pilot Telemetry";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="h3 mb-1">Pilot Telemetry</h1>
        <p class="text-muted mb-0 small">Product usage events for the last @Model.Days day(s).</p>
    </div>
    <form method="get" class="d-flex align-items-center gap-2">
        <label class="form-label small text-muted mb-0">Period:</label>
        <select name="days" class="form-select form-select-sm" style="width:120px" onchange="this.form.submit()">
            @foreach (var d in new[] { 7, 14, 30, 90 })
            {
                <option value="@d" selected="@(Model.Days == d)">Last @d days</option>
            }
        </select>
    </form>
</div>

@if (Model.LoadError is not null)
{
    <div class="alert alert-danger">@Model.LoadError</div>
}
else if (Model.Dashboard is null)
{
    <div class="alert alert-secondary">No telemetry data available.</div>
}
else
{
    var dashboard = Model.Dashboard;
    var categories = dashboard.Summary.GroupBy(s => s.Category).OrderBy(g => g.Key);

    @* ── Summary by category ── *@
    <div class="row g-3 mb-4">
        @foreach (var cat in categories)
        {
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header fw-semibold small d-flex align-items-center justify-content-between">
                        @Html.Raw(CategoryBadge(cat.Key))
                        <span class="text-muted small">@cat.Sum(e => e.Count) total</span>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-sm small mb-0">
                            <tbody>
                                @foreach (var entry in cat.OrderByDescending(e => e.Count))
                                {
                                    <tr>
                                        <td class="font-monospace ps-3">@entry.EventName</td>
                                        <td class="text-end pe-3 fw-semibold">@entry.Count</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!categories.Any())
    {
        <div class="alert alert-secondary mb-4">
            No telemetry events recorded in the last @Model.Days days.
        </div>
    }

    @* ── Recent events ── *@
    <div class="card shadow-sm">
        <div class="card-header fw-semibold d-flex align-items-center justify-content-between">
            <span>Recent Events</span>
            <span class="text-muted small">@dashboard.RecentEvents.Count shown (max 500)</span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover table-sm small align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Time (UTC)</th>
                        <th>Category</th>
                        <th>Event</th>
                        <th>Status</th>
                        <th>Workflow</th>
                        <th>Instance ID</th>
                        <th>Definition ID</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var evt in dashboard.RecentEvents)
                    {
                        <tr>
                            <td class="text-muted text-nowrap">@evt.OccurredAtUtc.UtcDateTime.ToString("MM-dd HH:mm:ss")</td>
                            <td>@Html.Raw(CategoryBadge(evt.Category))</td>
                            <td class="font-monospace">@evt.EventName</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(evt.Status))
                                {
                                    @Html.Raw(StatusBadge(evt.Status))
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(evt.WorkflowKey))
                                {
                                    <span class="font-monospace">@evt.WorkflowKey</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                @if (evt.WorkflowInstanceId.HasValue)
                                {
                                    <a href="/ops/workflows/details?id=@evt.WorkflowInstanceId"
                                       class="font-monospace text-decoration-none small">@evt.WorkflowInstanceId.Value</a>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                @if (evt.WorkflowDefinitionId.HasValue)
                                {
                                    <a href="/ops/definitions/edit?id=@evt.WorkflowDefinitionId"
                                       class="font-monospace text-decoration-none small">@evt.WorkflowDefinitionId.Value</a>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* ── Event Reference ── *@
    <details class="mt-4">
        <summary class="fw-semibold small text-muted" style="cursor:pointer">Event Reference</summary>
        <div class="card shadow-sm mt-2">
            <div class="card-body p-0">
                <table class="table table-sm small mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Event</th>
                            <th>Category</th>
                            <th>When it fires</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td class="ps-3 font-monospace">workflow_started</td><td>Execution</td><td>New instance created (webhook, manual, or schedule trigger)</td></tr>
                        <tr><td class="ps-3 font-monospace">workflow_failed</td><td>Execution</td><td>Instance enters Failed state (retries exhausted or permanent failure)</td></tr>
                        <tr><td class="ps-3 font-monospace">manual_retry_triggered</td><td>Execution</td><td>User retries a failed instance from the last failed step</td></tr>
                        <tr><td class="ps-3 font-monospace">replay_triggered</td><td>Execution</td><td>User replays an instance from step 1</td></tr>
                        <tr class="table-light"><td colspan="3" class="ps-3 fw-semibold text-muted">Authoring</td></tr>
                        <tr><td class="ps-3 font-monospace">workflow_created_from_template</td><td>Authoring</td><td>Definition created from a template</td></tr>
                        <tr><td class="ps-3 font-monospace">workflow_created_blank</td><td>Authoring</td><td>Blank definition created</td></tr>
                        <tr><td class="ps-3 font-monospace">workflow_cloned</td><td>Authoring</td><td>Definition cloned from another</td></tr>
                        <tr><td class="ps-3 font-monospace">workflow_activated</td><td>Authoring</td><td>Definition activated (ready to trigger)</td></tr>
                        <tr><td class="ps-3 font-monospace">workflow_deactivated</td><td>Authoring</td><td>Definition deactivated</td></tr>
                        <tr class="table-light"><td colspan="3" class="ps-3 fw-semibold text-muted">Errors</td></tr>
                        <tr><td class="ps-3 font-monospace">activation_failed</td><td>Error</td><td>Activation validation failed (missing config, no steps)</td></tr>
                        <tr><td class="ps-3 font-monospace">alert_delivery_failed</td><td>Error</td><td>Alert webhook delivery failed</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </details>
}

@functions {
    static string StatusBadge(string status) => status switch
    {
        "Pending"  => "<span class=\"badge bg-secondary\">Pending</span>",
        "Running"  => "<span class=\"badge bg-primary\">Running</span>",
        "Failed"   => "<span class=\"badge bg-danger\">Failed</span>",
        "Active"   => "<span class=\"badge bg-success\">Active</span>",
        "Inactive" => "<span class=\"badge bg-secondary\">Inactive</span>",
        "Completed"=> "<span class=\"badge bg-success\">Completed</span>",
        _          => $"<span class=\"badge bg-light text-dark border\">{status}</span>"
    };

    static string CategoryBadge(string category) => category switch
    {
        "Authoring" => "<span class=\"badge bg-primary\">Authoring</span>",
        "Execution" => "<span class=\"badge bg-success\">Execution</span>",
        "Error"     => "<span class=\"badge bg-danger\">Error</span>",
        _           => $"<span class=\"badge bg-secondary\">{category}</span>"
    };
}
